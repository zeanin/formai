{
  "name": "formai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native No-Code Application Platform",
  "scripts": {
    "dev": "turbo run dev --concurrency=64",
    "dev:server": "turbo run dev --filter=@formai/app-server",
    "dev:web": "turbo run dev --filter=@formai/app-web",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:migrate": "node apps/server/dist/migrate.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0",
    "eslint": "^9.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
