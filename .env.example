# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=formai
DB_PASSWORD=formai
DB_NAME=formai
DB_LOGGING=false

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── AI Providers ─────────────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage/uploads

# ─── Redis (for token blacklist, cache) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
