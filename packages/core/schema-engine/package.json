{
  "name": "@formai/schema-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Formai schema engine - React-based recursive schema renderer",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react --tsconfig tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint src/",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@formai/shared": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "module": "./dist/index.mjs"
}
