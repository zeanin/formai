{
  "name": "@formai/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Formai SDK for building plugins and extensions",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@formai/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
