{
  "name": "@formai/plugin-codex",
  "version": "0.1.0",
  "description": "Codex integration plugin for Formai — wraps Codex headless coding agent turns and sessions",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --shims --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format esm,cjs --shims --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@formai/shared": "workspace:*",
    "@formai/plugin": "workspace:*",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.24.1",
    "@modelcontextprotocol/sdk": "^1.2.0"
  },
  "devDependencies": {
    "koa": "^2.15.0",
    "@types/koa": "^2.15.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
