{
  "name": "@formai/app-server",
  "version": "0.1.0",
  "private": true,
  "description": "Formai server application",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "koa": "^2.15.0",
    "@koa/router": "^12.0.0",
    "koa-bodyparser": "^4.4.0",
    "koa-cors": "^0.0.16",
    "@formai/database": "workspace:*",
    "@formai/server": "workspace:*",
    "@formai/auth": "workspace:*",
    "@formai/acl": "workspace:*",
    "@formai/resourcer": "workspace:*",
    "@formai/plugin": "workspace:*",
    "@formai/shared": "workspace:*",
    "@formai/plugin-collection-manager": "workspace:*",
    "@formai/plugin-auth": "workspace:*",
    "@formai/plugin-ai": "workspace:*",
    "@formai/plugin-users": "workspace:*",
    "@formai/plugin-acl": "workspace:*",
    "@formai/plugin-ui-schema-storage": "workspace:*",
    "@formai/plugin-file-manager": "workspace:*",
    "@formai/plugin-system-settings": "workspace:*",
    "@formai/plugin-localization": "workspace:*",
    "@formai/plugin-notification": "workspace:*",
    "@formai/plugin-workflow": "workspace:*",
    "@formai/plugin-data-visualization": "workspace:*",
    "@formai/plugin-import-export": "workspace:*",
    "@formai/plugin-backup-restore": "workspace:*",
    "@formai/plugin-audit-log": "workspace:*",
    "@formai/plugin-api-doc": "workspace:*",
    "@formai/plugin-theme-editor": "workspace:*",
    "@formai/plugin-apps": "workspace:*"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.0",
    "@types/koa-bodyparser": "^4.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
